{
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "es5",
  "importOrder": [
    ".*styles.css$",
    "",
    "dayjs",
    "^react$",
    "^next$",
    "^next/.*$",
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "^@mantine/(.*)$",
    "^@mantinex/(.*)$",
    "^@mantine-tests/(.*)$",
    "^@docs/(.*)$",
    "^@/.*$",
    "^../(?!.*\\.css$).*$",
    "^./(?!.*\\.css$).*$",
    "\\.module\\.css$",
    "(?<!\\.module)\\.css$"
  ],
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.d.ts",
    "*.mdx",
    "*.md",
    "packages/*/*/styles.css",
    "packages/*/*/styles.layer.css",
    "packages/*/*/styles/*.css",
    "docs/.next",
    "docs/out"
  ]
}
